transcript on
if {[file exists rtl_work]} {
	vdel -lib rtl_work -all
}
vlib rtl_work
vmap work rtl_work

vcom -93 -work work {/home/samuel/Documentos/circuitos/debounce.vhd}
vcom -93 -work work {/home/samuel/Documentos/circuitos/datapath.vhd}
vcom -93 -work work {/home/samuel/Documentos/circuitos/mef.vhd}
vcom -93 -work work {/home/samuel/Documentos/circuitos/display_7seg.vhd}
vcom -93 -work work {/home/samuel/Documentos/circuitos/top_level.vhd}

vcom -93 -work work {/home/samuel/Documentos/circuitos/tb_top_level.vhd}

vsim -t 1ps -L altera -L lpm -L sgate -L altera_mf -L altera_lnsim -L cycloneii -L rtl_work -L work -voptargs="+acc"  tb_top_level

add wave *
view structure
view signals
run -all
