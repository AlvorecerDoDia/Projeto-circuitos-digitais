		$display ("     Real value = %b", hex_unidades_prev);
		nummismatches = nummismatches + 1;
		on_first_change[3] = 1'b0;
		last_hex_unidades_exp[4] = hex_unidades_expected_prev[4];
	end
	if (
		( hex_unidades_expected_prev[5] !== 1'bx ) && ( hex_unidades_prev[5] !== hex_unidades_expected_prev[5] )
		&& ((hex_unidades_expected_prev[5] !== last_hex_unidades_exp[5]) ||
			on_first_change[3])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port hex_unidades[5] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", hex_unidades_expected_prev);
		$display ("     Real value = %b", hex_unidades_prev);
		nummismatches = nummismatches + 1;
		on_first_change[3] = 1'b0;
		last_hex_unidades_exp[5] = hex_unidades_expected_prev[5];
	end
	if (
		( hex_unidades_expected_prev[6] !== 1'bx ) && ( hex_unidades_prev[6] !== hex_unidades_expected_prev[6] )
		&& ((hex_unidades_expected_prev[6] !== last_hex_unidades_exp[6]) ||
			on_first_change[3])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port hex_unidades[6] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", hex_unidades_expected_prev);
		$display ("     Real value = %b", hex_unidades_prev);
		nummismatches = nummismatches + 1;
		on_first_change[3] = 1'b0;
		last_hex_unidades_exp[6] = hex_unidades_expected_prev[6];
	end
	if (
		( led_devolver_expected_prev !== 1'bx ) && ( led_devolver_prev !== led_devolver_expected_prev )
		&& ((led_devolver_expected_prev !== last_led_devolver_exp) ||
			on_first_change[4])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port led_devolver :: @time = %t",  $realtime);
		$display ("     Expected value = %b", led_devolver_expected_prev);
		$display ("     Real value = %b", led_devolver_prev);
		nummismatches = nummismatches + 1;
		on_first_change[4] = 1'b0;
		last_led_devolver_exp = led_devolver_expected_prev;
	end
	if (
		( led_liberar_expected_prev !== 1'bx ) && ( led_liberar_prev !== led_liberar_expected_prev )
		&& ((led_liberar_expected_prev !== last_led_liberar_exp) ||
			on_first_change[5])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port led_liberar :: @time = %t",  $realtime);
		$display ("     Expected value = %b", led_liberar_expected_prev);
		$display ("     Real value = %b", led_liberar_prev);
		nummismatches = nummismatches + 1;
		on_first_change[5] = 1'b0;
		last_led_liberar_exp = led_liberar_expected_prev;
	end
	if (
		( led_sem_estoque_expected_prev !== 1'bx ) && ( led_sem_estoque_prev !== led_sem_estoque_expected_prev )
		&& ((led_sem_estoque_expected_prev !== last_led_sem_estoque_exp) ||
			on_first_change[6])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port led_sem_estoque :: @time = %t",  $realtime);
		$display ("     Expected value = %b", led_sem_estoque_expected_prev);
		$display ("     Real value = %b", led_sem_estoque_prev);
		nummismatches = nummismatches + 1;
		on_first_change[6] = 1'b0;
		last_led_sem_estoque_exp = led_sem_estoque_expected_prev;
	end
	if (
		( led_troco_expected_prev !== 1'bx ) && ( led_troco_prev !== led_troco_expected_prev )
		&& ((led_troco_expected_prev !== last_led_troco_exp) ||
			on_first_change[7])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port led_troco :: @time = %t",  $realtime);
		$display ("     Expected value = %b", led_troco_expected_prev);
		$display ("     Real value = %b", led_troco_prev);
		nummismatches = nummismatches + 1;
		on_first_change[7] = 1'b0;
		last_led_troco_exp = led_troco_expected_prev;
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#2000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module top_level_vlg_vec_tst();
// constants                                           
// general purpose registers
reg btn_confirmar;
reg btn_desistir;
reg btn_inserir_moeda;
reg [2:0] ch_produto;
reg ch_reset;
reg [2:0] ch_valor_moeda;
reg clk_50;
// wires                                               
wire [6:0] hex_centenas;
wire [6:0] hex_dezenas;
wire [6:0] hex_unidades;
wire led_devolver;
wire led_liberar;
wire led_sem_estoque;
wire led_troco;

wire sampler;                             

// assign statements (if any)                          
top_level i1 (
// port map - connection between master ports and signals/registers   
	.btn_confirmar(btn_confirmar),
	.btn_desistir(btn_desistir),
	.btn_inserir_moeda(btn_inserir_moeda),
	.ch_produto(ch_produto),
	.ch_reset(ch_reset),
	.ch_valor_moeda(ch_valor_moeda),
	.clk_50(clk_50),
	.hex_centenas(hex_centenas),
	.hex_dezenas(hex_dezenas),
	.hex_unidades(hex_unidades),
	.led_devolver(led_devolver),
	.led_liberar(led_liberar),
	.led_sem_estoque(led_sem_estoque),
	.led_troco(led_troco)
);

// clk_50
initial
begin
	repeat(49)
	begin
		clk_50 = 1'b0;
		clk_50 = #10000 1'b1;
		# 10000;
	end
	clk_50 = 1'b0;
	clk_50 = #10000 1'b1;
	# 9000;
	repeat(50)
	begin
		clk_50 = 1'b0;
		clk_50 = #10000 1'b1;
		# 10000;
	end
	clk_50 = 1'b0;
end 

// btn_confirmar
initial
begin
	btn_confirmar = 1'b1;
	btn_confirmar = #400000 1'b0;
	btn_confirmar = #60000 1'b1;
end 

// btn_desistir
initial
begin
	btn_desistir = 1'b1;
end 

// btn_inserir_moeda
initial
begin
	btn_inserir_moeda = 1'b1;
	btn_inserir_moeda = #80000 1'b0;
	btn_inserir_moeda = #80000 1'b1;
	btn_inserir_moeda = #80000 1'b0;
	btn_inserir_moeda = #80000 1'b1;
end 

// ch_reset
initial
begin
	ch_reset = 1'b1;
	ch_reset = #40000 1'b0;
end 
// ch_produto[ 2 ]
initial
begin
	ch_produto[2] = 1'b0;
end 
// ch_produto[ 1 ]
initial
begin
	ch_produto[1] = 1'b0;
end 
// ch_produto[ 0 ]
initial
begin
	ch_produto[0] = 1'b0;
	ch_produto[0] = #40000 1'b1;
	ch_produto[0] = #660000 1'b0;
end 
// ch_valor_moeda[ 2 ]
initial
begin
	ch_valor_moeda[2] = 1'b0;
end 
// ch_valor_moeda[ 1 ]
initial
begin
	ch_valor_moeda[1] = 1'b0;
	ch_valor_moeda[1] = #40000 1'b1;
	ch_valor_moeda[1] = #660000 1'b0;
end 
// ch_valor_moeda[ 0 ]
initial
begin
	ch_valor_moeda[0] = 1'b0;
	ch_valor_moeda[0] = #40000 1'b1;
	ch_valor_moeda[0] = #660000 1'b0;
end 

top_level_vlg_sample_tst tb_sample (
	.btn_confirmar(btn_confirmar),
	.btn_desistir(btn_desistir),
	.btn_inserir_moeda(btn_inserir_moeda),
	.ch_produto(ch_produto),
	.ch_reset(ch_reset),
	.ch_valor_moeda(ch_valor_moeda),
	.clk_50(clk_50),
	.sampler_tx(sampler)
);

top_level_vlg_check_tst tb_out(
	.hex_centenas(hex_centenas),
	.hex_dezenas(hex_dezenas),
	.hex_unidades(hex_unidades),
	.led_devolver(led_devolver),
	.led_liberar(led_liberar),
	.led_sem_estoque(led_sem_estoque),
	.led_troco(led_troco),
	.sampler_rx(sampler)
);
endmodule

