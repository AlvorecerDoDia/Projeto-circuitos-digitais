`timescale 1 ps/ 1 ps
module top_level_vlg_sample_tst(
	btn_confirmar,
	btn_desistir,
	btn_inserir_moeda,
	ch_produto,
	ch_reset,
	ch_valor_moeda,
	clk_50,
	sampler_tx
);
input  btn_confirmar;
input  btn_desistir;
input  btn_inserir_moeda;
input [2:0] ch_produto;
input  ch_reset;
input [2:0] ch_valor_moeda;
input  clk_50;
output sampler_tx;

reg sample;
time current_time;
always @(btn_confirmar or btn_desistir or btn_inserir_moeda or ch_produto or ch_reset or ch_valor_moeda or clk_50)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

